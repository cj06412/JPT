# Visual brainstorm artifacts (kept outside repo intentionally)
.superpowers/

# Node / Electron
node_modules/
dist/
dist-electron/
out/
build/
release/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite
.vite/

# tsc emit guard — Vite/esbuild does the real bundling; tsc is a type-check
# gate only (build script uses `tsc --noEmit`). Never commit in-place compiled
# output next to TS sources if a stray `tsc -b` ever emits it.
src/**/*.js
src/**/*.d.ts
electron/**/*.js
electron/**/*.d.ts
tests/**/*.js
*.tsbuildinfo
vite.config.js
vite.config.d.ts
vitest.config.js
vitest.config.d.ts
# Keep the hand-written static CJS preload (not tsc output).
!electron/preload.cjs.js

# Local env / secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Electron-builder output
*.exe
*.dmg
*.AppImage
*.deb
*.snap
*.zip
!assets/**/*.zip

# Generated AI assets work-in-progress
assets/sprites/_drafts/
assets/sprites/*.aseprite

# Python (if any tooling lands here later)
__pycache__/
*.pyc
.venv/
venv/
